# ============================================================
# Screenshot AI Solver — 环境变量配置模板
# ============================================================
# 使用方法:
#   1. 复制此文件为 .env:  cp .env.example .env
#   2. 填入你的 API 密钥
#   3. .env 文件已被 .gitignore 忽略，不会上传到 GitHub
# ============================================================

# 必填: API 密钥
SCREENSHOT_AI_API_KEY=sk-your-api-key-here

# 选填: API Base URL (使用 OpenAI 官方则无需修改)
SCREENSHOT_AI_BASE_URL=https://api.openai.com/v1

# 选填: 模型名称
SCREENSHOT_AI_MODEL=gpt-4o

# 选填: 是否启用 GPU 加速 OCR (true/false)
SCREENSHOT_AI_GPU=false
